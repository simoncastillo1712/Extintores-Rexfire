# =====================================================
#  EXTINTORES REXFIRE — .gitignore
# =====================================================

# Variables de entorno (NUNCA commitear — contiene API keys y contraseñas)
.env
.env.local
.env.production

# Bytecode Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Logs
*.log
django.log
cloudflared.log

# Media uploads (archivos subidos por usuarios — no van en git)
media/

# Archivos estáticos compilados (generados por collectstatic)
staticfiles/

# Entorno virtual
venv/
env/
.venv/

# Distribución / empaquetado
*.egg-info/
dist/
build/
*.egg
MANIFEST

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Cloudflare
cloudflared.exe
