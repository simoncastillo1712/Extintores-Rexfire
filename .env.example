# =====================================================
#  EXTINTORES REXFIRE — Variables de Entorno
#  Copia este archivo como .env y completa los valores
# =====================================================

# --- Django ---
SECRET_KEY=cambia-esto-por-una-clave-secreta-aleatoria-larga
DEBUG=True
# En producción: DEBUG=False
# ALLOWED_HOSTS=extintoresrexfire.cl,www.extintoresrexfire.cl

# --- Base de datos MySQL ---
DB_NAME=extintores
DB_USER=root
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=3306
# En Railway: estos valores los provee el servicio MySQL de Railway

# --- DeepSeek AI (chatbot REXI) ---
# Obtén tu key en: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Twilio WhatsApp Sandbox ---
# Configura en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Gmail SMTP (envío de cotizaciones) ---
# Genera una Contraseña de Aplicación en: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
